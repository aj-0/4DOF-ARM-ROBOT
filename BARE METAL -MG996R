#include "stm32f4xx.h"  //PA0

/* -------- Delay (rough, depends on 16MHz HSI) -------- */
void delay_ms(uint32_t ms)
{
    for(uint32_t i = 0; i < ms * 4000; i++)
        __NOP();
}

/* -------- PWM Init (PA0 → TIM2_CH1) -------- */
void pwm_init(void)
{
    // Enable clocks
    RCC->AHB1ENR |= (1 << 0);   // GPIOA
    RCC->APB1ENR |= (1 << 0);   // TIM2

    // PA0 → Alternate Function
    GPIOA->MODER &= ~(3 << (0 * 2));
    GPIOA->MODER |=  (2 << (0 * 2));

    // AF1 (TIM2)
    GPIOA->AFR[0] &= ~(0xF << (0 * 4));
    GPIOA->AFR[0] |=  (1 << (0 * 4));

    // Timer config (16 MHz HSI → 1 µs tick)
    TIM2->PSC = 15;      // 16MHz / 16 = 1 MHz
    TIM2->ARR = 20000;   // 20 ms → 50 Hz

    // PWM mode 1
    TIM2->CCMR1 &= ~(7 << 4);
    TIM2->CCMR1 |=  (6 << 4);
    TIM2->CCMR1 |=  (1 << 3);   // preload enable

    TIM2->CCER |= (1 << 0);     // enable CH1

    TIM2->CCR1 = 1500;          // center (safe start)

    TIM2->CR1 |= (1 << 7);      // ARPE
    TIM2->CR1 |= (1 << 0);      // start timer
}

/* -------- Servo control -------- */
void set_angle(uint8_t angle)
{
    // 0° → 500 µs, 180° → 2500 µs
    uint32_t pulse = 500 + ((2000 * angle) / 180);
    TIM2->CCR1 = pulse;
}

/* -------- Main -------- */
int main(void)
{
    pwm_init();

    while (1)
    {
        // MAX SPEED forward
        set_angle(180);
        delay_ms(600);   // allow full movement

        // MAX SPEED reverse
        set_angle(0);
        delay_ms(600);
    }
}
