  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
}

.slider {
  width: 100%;
}

.value {
  color: #00e5ff;
}

</style>
</head>

<body>

<h1>🤖 AJ's Automation</h1>

<div class="container">

<div class="card">
<span>Base <span id="v1">90</span></span>
<input type="range" min="0" max="180" value="90" oninput="update(1,this.value)">
</div>

<div class="card">
<span>Shoulder <span id="v2">90</span></span>
<input type="range" min="0" max="180" value="90" oninput="update(2,this.value)">
</div>

<div class="card">
<span>Elbow <span id="v3">90</span></span>
<input type="range" min="0" max="180" value="90" oninput="update(3,this.value)">
</div>

<div class="card">
<span>Wrist <span id="v4">90</span></span>
<input type="range" min="0" max="180" value="90" oninput="update(4,this.value)">
</div>

<div class="card" style="grid-column: span 2;">
<span>Gripper <span id="v5">90</span></span>
<input type="range" min="0" max="180" value="90" oninput="update(5,this.value)">
</div>

</div>

<script>
function update(servo, value) {
  document.getElementById("v"+servo).innerHTML = value;

  var xhttp = new XMLHttpRequest();
  xhttp.open("GET", "/set?servo=" + servo + "&value=" + value, true);
  xhttp.send();
}
</script>

