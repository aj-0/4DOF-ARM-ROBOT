#include <WiFi.h> // bore UI

// WiFi AP
const char* ssid = "ESP32_ARM";
const char* password = "12345678";

WiFiServer server(80);

// UART2 pins
#define RXD2 16
#define TXD2 17

String header;

// store angles
int angles[5] = {90, 90, 90, 90, 90};

// ================= SETUP =================
void setup() {
  Serial.begin(115200);

  // UART2 → STM32
  Serial2.begin(115200, SERIAL_8N1, RXD2, TXD2);

  WiFi.softAP(ssid, password);
  Serial.println("AP Started");
  Serial.println(WiFi.softAPIP());

  server.begin();
}

// ================= SEND DATA =================
void sendToSTM32() {
  String data = String(angles[0]) + "," +
                String(angles[1]) + "," +
                String(angles[2]) + "," +
                String(angles[3]) + "," +
                String(angles[4]) + "\n";

  Serial2.print(data);

  Serial.print("Sent: ");
  Serial.println(data);
}

// ================= HANDLE REQUEST =================
void handleServo(String req) {
  int s = req.indexOf("servo=");
  int v = req.indexOf("value=");

  if (s != -1 && v != -1) {
    int servo = req.substring(s + 6).toInt();
    int value = req.substring(v + 6).toInt();

    value = constrain(value, 0, 180);

    if (servo >= 1 && servo <= 5) {
      angles[servo - 1] = value;

      sendToSTM32();   // 🔥 SEND TO STM32
    }
  }
}

// ================= LOOP =================
void loop() {
  WiFiClient client = server.available();

  if (client) {
    header = "";
    unsigned long timeout = millis();

    while (client.connected() && millis() - timeout < 2000) {
      if (client.available()) {
        char c = client.read();
        header += c;

        if (c == '\n') {

          // -------- CONTROL --------
          if (header.indexOf("GET /set?") >= 0) {
            handleServo(header);

            client.println("HTTP/1.1 200 OK");
            client.println("Content-type:text/plain");
            client.println();
            client.println("OK");
            break;
          }

          // -------- WEB UI --------
          client.println("HTTP/1.1 200 OK");
          client.println("Content-type:text/html");
          client.println();

          client.println(R"rawliteral(
<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>AJ's Automation</title>

<style>
body {
  margin: 0;
  font-family: 'Segoe UI', sans-serif;
  background: linear-gradient(145deg, #0a0f1c, #111827);
  color: white;
}

