#include <WiFi.h>

// WiFi AP
const char* ssid = "ESP32_ARM";
const char* password = "12345678";

WiFiServer server(80);

// UART2 pins
#define RXD2 16
#define TXD2 17

String header;

// limits
int minLimit[5] = {20, 30, 40, 30, 20};
int maxLimit[5] = {160,140,150,150,80};

// store angles
int angles[5] = {90, 90, 90, 90, 30};

// ================= SETUP =================
void setup() {
  Serial.begin(115200);
  Serial2.begin(115200, SERIAL_8N1, RXD2, TXD2);

  WiFi.softAP(ssid, password);
  Serial.println(WiFi.softAPIP());

  server.begin();
}

// ================= SEND =================
void sendToSTM32() {
  String data = String(angles[0]) + "," +
                String(angles[1]) + "," +
                String(angles[2]) + "," +
                String(angles[3]) + "," +
                String(angles[4]) + "\n";

  Serial2.print(data);

  Serial.print("Sent: ");
  Serial.println(data);
}

// ================= HANDLE =================
void handleServo(String req) {
  int s = req.indexOf("servo=");
  int v = req.indexOf("value=");

  if (s != -1 && v != -1) {
    int servo = req.substring(s + 6).toInt();
    int value = req.substring(v + 6).toInt();

    if (servo >= 1 && servo <= 5) {
      // 🔥 APPLY LIMIT HERE
      value = constrain(value,
                        minLimit[servo-1],
                        maxLimit[servo-1]);

      angles[servo - 1] = value;

      sendToSTM32();
    }
  }
}

// ================= LOOP =================
void loop() {
  WiFiClient client = server.available();

  if (client) {
    header = "";
    unsigned long timeout = millis();

    while (client.connected() && millis() - timeout < 2000) {
      if (client.available()) {
        char c = client.read();
        header += c;

        if (c == '\n') {

          if (header.indexOf("GET /set?") >= 0) {
            handleServo(header);

            client.println("HTTP/1.1 200 OK");
            client.println("Content-type:text/plain");
            client.println();
            client.println("OK");
            break;
          }

          // ================= UI =================
          client.println("HTTP/1.1 200 OK");
          client.println("Content-type:text/html");
          client.println();

          client.println(R"rawliteral(
<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>AJ's Automation</title>

<style>
body {
  margin: 0;
  font-family: 'Segoe UI';
  background: #0a0f1c;
  color: white;
}

h1 {
  text-align: center;
  color: #00e5ff;
}

.container {
  display: grid;
  grid-template-columns: repeat(2,1fr);
  gap: 15px;
  padding: 20px;
}

.card {
  background: rgba(255,255,255,0.05);
  padding: 15px;
  border-radius: 10px;
}

</style>
</head>

<body>

<h1>🤖 AJ's Automation</h1>

<div class="container">

<div class="card">
Base <span id="v1">90</span>
<input type="range" min="20" max="160" value="90"
oninput="update(1,this.value)">
</div>

<div class="card">
Shoulder <span id="v2">90</span>
<input type="range" min="30" max="140" value="90"
oninput="update(2,this.value)">
</div>

<div class="card">
Elbow <span id="v3">90</span>
<input type="range" min="40" max="150" value="90"
oninput="update(3,this.value)">
</div>

<div class="card">
Wrist <span id="v4">90</span>
<input type="range" min="30" max="150" value="90"
oninput="update(4,this.value)">
</div>

<div class="card" style="grid-column: span 2;">
Gripper <span id="v5">30</span>
<input type="range" min="20" max="80" value="30"
oninput="update(5,this.value)">
</div>

</div>

<script>
function update(servo, value) {
  document.getElementById("v"+servo).innerHTML = value;

  var xhttp = new XMLHttpRequest();
  xhttp.open("GET", "/set?servo=" + servo + "&value=" + value, true);
  xhttp.send();
}
</script>

</body>
</html>
)rawliteral");

          break;
        }
      }
    }
    client.stop();
  }
}
